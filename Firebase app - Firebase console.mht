@charset "utf-8";

#bootanim-logo { --light-scheme-background-color: #fafafa; --dark-scheme-background-color: #121212; align-items: center; inset: 0px; display: flex; flex-direction: column; justify-content: center; opacity: 1; position: absolute; transform: translateZ(0px); z-index: 999; }

#bootanim-logo.fire-scheme-light { background-color: var(--light-scheme-background-color); }

#bootanim-logo.fire-scheme-dark { background-color: var(--dark-scheme-background-color); }

#bootanim-logo.fire-scheme-default {
  background-color: var(--light-scheme-background-color);
  @media (prefers-color-scheme: dark) {
  background-color: var(--dark-scheme-background-color);
}
}

#bootanim-logo--spinner { animation: 0.6s ease 0s 1 normal forwards running bootanim-logo--spinner-fade, 1s linear 0s infinite normal running bootanim-logo--spinner-rotate; height: 48px; margin-top: 0px; opacity: 0; width: 48px; }

@keyframes bootanim-logo--spinner-fade { 
  0% { opacity: 0; }
  100% { opacity: 1; }
}

@keyframes bootanim-logo--spinner-rotate { 
  0% { transform: translateZ(0px) rotate(0deg); }
  100% { transform: translateZ(0px) rotate(360deg); }
}
